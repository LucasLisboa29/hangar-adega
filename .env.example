# ─────────────────────────────────────────────────────────────
# Variáveis de ambiente — Plataforma Hangar Bebidas
# Copie este arquivo para `.env` e preencha com os valores reais.
# NUNCA versione o `.env` (já está no .gitignore).
# ─────────────────────────────────────────────────────────────

# Banco de dados (Supabase Postgres)
# DATABASE_URL  -> conexão POOLED (Supavisor, porta 6543) usada pelo app em runtime.
# DIRECT_URL    -> conexão DIRETA (porta 5432) usada pelas migrations/seed.
# Pegue as duas em: Supabase > Project Settings > Database > Connection string.
DATABASE_URL="postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Auth do admin (Fase 3) — gere um segredo com:  openssl rand -base64 32
# AUTH_SECRET=""

# Supabase (Storage de imagens dos produtos — Fase 3)
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# SUPABASE_SERVICE_ROLE_KEY=""

# WhatsApp que recebe os pedidos (Fase 2) — só dígitos, com DDI/DDD. Ex.: 5534XXXXXXXXX
# NEXT_PUBLIC_WHATSAPP_NUMERO=""
